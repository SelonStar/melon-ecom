<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.melonecom.mapper.PayTxnMapper">

    <resultMap id="PayTxnResultMap" type="com.melonecom.model.entity.PayTxn">
        <id column="id" property="payTxnId"/>
        <result column="order_no" property="orderNo"/>
        <result column="user_id" property="userId"/>
        <result column="pay_type" property="payType"/>
        <result column="amount" property="amount"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="PayTxnColumns">
        id, order_no, user_id, pay_type, amount, status, create_time
    </sql>

    <!-- MySQL：幂等插入，order_no 冲突则忽略 -->
    <insert id="insertIgnore">
        INSERT IGNORE INTO tb_pay_txn (order_no, user_id, pay_type, amount, status)
        VALUES (#{orderNo}, #{userId}, #{payType}, #{amount}, #{status})
    </insert>

    <!-- CAS 状态流转 -->
    <update id="updateStatusCas">
        UPDATE tb_pay_txn
        SET status = #{toStatus}
        WHERE order_no = #{orderNo}
          AND status = #{fromStatus}
    </update>

    <select id="selectByOrderNo" resultMap="PayTxnResultMap">
        SELECT <include refid="PayTxnColumns"/>
        FROM tb_pay_txn
        WHERE order_no = #{orderNo}
        LIMIT 1
    </select>

</mapper>
